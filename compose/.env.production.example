# Production Environment — Example
# Copy this to /opt/Traders/compose/.env and customize

SITE_NAME=trader.yourcompany.com
BENCH_NAME=frappe-bench

# Database (CHANGE THESE!)
DB_HOST=db
DB_PORT=3306
DB_ROOT_PASSWORD=$(openssl rand -base64 32)
MYSQL_DATABASE=trader_production

# Redis
REDIS_CACHE=redis-cache:6379
REDIS_QUEUE=redis-queue:6379

# Admin (CHANGE THIS!)
ADMIN_PASSWORD=$(openssl rand -base64 24)
ENCRYPTION_KEY=$(openssl rand -hex 32)
SECRET_KEY=$(openssl rand -base64 48)

# Versions
FRAPPE_VERSION=v15.47.4
ERPNEXT_VERSION=v15.37.2

# Frontend
VITE_API_URL=https://trader.yourcompany.com/api
VITE_SITE_NAME=trader.yourcompany.com

# Ports (use nginx/caddy reverse proxy in front)
HTTP_PORT=8080
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Workers (adjust based on server size)
WORKER_CLASS=gthread
GUNICORN_WORKERS=8
GUNICORN_THREADS=4

# Backup retention
BACKUP_RETENTION_DAYS=90
